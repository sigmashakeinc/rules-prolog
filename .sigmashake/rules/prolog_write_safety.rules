# prolog_write_safety.rules
# Technology: prolog | Capability: write

rule prolog-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_prolog_PATTERN"
  MESSAGE "Blocked an unsafe pattern in prolog. Use the recommended best practices for 2025/2026."
}

rule prolog-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_prolog_API"
  MESSAGE "You are using an outdated API for prolog. Please upgrade to the newer API."
}
